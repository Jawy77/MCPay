# MCPay Environment Variables
# Copy to each component's .env and fill in your values

# === Backend (backend/.env) ===
PORT=4000
MCP_SERVER_URL=http://localhost:3001/mcp
MOCK_PAYMENTS=true
CORS_ORIGIN=https://v0-mcp-ay-payment-gateway.vercel.app,http://localhost:3000

# thirdweb (sponsor) — get keys at https://thirdweb.com/dashboard
THIRDWEB_SECRET_KEY=your_thirdweb_secret_key
AUTH_DOMAIN=v0-mcp-ay-payment-gateway.vercel.app

# Wallet (admin signer for JWT + agent wallet)
ADMIN_PRIVATE_KEY=0x_your_private_key_here

# Coinbase CDP x402 facilitator
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_API_KEY_SECRET=your_cdp_api_key_secret

# Groq LLM
GROQ_API_KEY=gsk_your_groq_key_here

# === Agent (agent/.env) ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
GROQ_API_KEY=gsk_your_groq_key_here
LLM_MODEL=llama-3.1-8b-instant
MCPAY_BACKEND_URL=http://localhost:4000

# === Frontend (Vercel env vars) ===
# NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id

# === Demo MCP Server ===
MCP_PORT=3001
PAYEE_WALLET_ADDRESS=0x_your_wallet_to_receive_payments
FACILITATOR_URL=https://x402.org/facilitator
