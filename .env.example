# ShieldPay CRE Workflow Environment Variables
# Copy to .env and fill in your values

# Base Sepolia private key (for on-chain writes during simulation)
CRE_ETH_PRIVATE_KEY=0x_your_private_key_here

# ShieldVault deployed contract address
SHIELD_VAULT_ADDRESS=0x_deployed_contract_address

# Base Sepolia RPC
BASE_SEPOLIA_RPC=https://sepolia.base.org

# x402 Payment wallet (agent wallet for demo)
AGENT_PRIVATE_KEY=0x_agent_wallet_private_key

# Telegram bot token (for OpenClaw demo)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Claude API key (for OpenClaw brain)
ANTHROPIC_API_KEY=sk-ant-your_key_here
