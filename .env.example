# ShieldPay Environment Variables
# Copy to .env and fill in your values

# === Network ===
BASE_SEPOLIA_RPC=https://sepolia.base.org

# === Smart Contract ===
SHIELD_VAULT_ADDRESS=0x_deployed_contract_address
CRE_ETH_PRIVATE_KEY=0x_your_private_key_here

# === Agent (Telegram Bot) ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
GROQ_API_KEY=gsk_your_groq_key_here
LLM_MODEL=llama-3.3-70b-versatile
AGENT_PRIVATE_KEY=0x_agent_wallet_private_key
MCP_SERVER_URL=http://localhost:3001
CRE_WORKFLOW_URL=http://localhost:8080/shield-verify

# === Demo MCP Server (x402-gated) ===
PAYEE_WALLET_ADDRESS=0x_your_wallet_to_receive_payments
MCP_PORT=3001
FACILITATOR_URL=https://x402.org/facilitator
